# ─── Telegram ───────────────────────────────────────────────
# Токен бота который ПОЛУЧАЕТ лиды (тот что подключён к CRM/форме)
TELEGRAM_LEAD_BOT_TOKEN=

# Токен бота модерации (куда приходят черновики на одобрение)
TELEGRAM_MOD_BOT_TOKEN=

# Твой Telegram chat_id (узнать: написать @userinfobot в Telegram)
TELEGRAM_MOD_CHAT_ID=

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Twilio ──────────────────────────────────────────────────
# Account SID — на главной странице console.twilio.com
TWILIO_ACCOUNT_SID=

# Auth Token — там же, кнопка-глаз
TWILIO_AUTH_TOKEN=

# Твой Twilio номер в формате +1XXXXXXXXXX
TWILIO_PHONE_NUMBER=

# ─── App ─────────────────────────────────────────────────────
# URL твоего деплоя на Railway (без слеша в конце)
# Пример: https://sms-autoresponder-production.up.railway.app
WEBHOOK_BASE_URL=

# Порт (Railway подставляет автоматически, не трогай)
PORT=8000
